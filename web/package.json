{
	"name": "cobrust-studio-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"test:unit": "svelte-kit sync && vitest run",
		"test:unit:watch": "svelte-kit sync && vitest",
		"test:e2e": "playwright test --project=hermetic",
		"test:e2e:agent": "playwright test --config=playwright-agent.config.ts",
		"test:e2e:i18n": "playwright test --config=playwright-i18n.config.ts",
		"test:e2e:dogfood": "playwright test --config=playwright-dogfood.config.ts",
		"test:e2e:setup": "playwright install --with-deps chromium",
		"tauri:dev": "pnpm build && cargo run --manifest-path ../src-tauri/Cargo.toml",
		"tauri:build": "tauri build --config ../src-tauri/tauri.conf.json"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-static": "^3.0.5",
		"@sveltejs/kit": "^2.8.1",
		"@sveltejs/vite-plugin-svelte": "^4.0.0",
		"@tailwindcss/vite": "^4.0.0",
		"@tauri-apps/cli": "^2.0.0",
		"@types/node": "^22.9.0",
		"@vitest/ui": "^3.2.4",
		"jsdom": "^29.1.1",
		"prettier": "^3.3.3",
		"prettier-plugin-svelte": "^3.2.6",
		"svelte": "^5.1.13",
		"svelte-check": "^4.0.5",
		"tailwindcss": "^4.0.0",
		"tslib": "^2.8.1",
		"typescript": "^5.6.3",
		"vite": "^5.4.10",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"bits-ui": "^1.0.0-next.65",
		"clsx": "^2.1.1",
		"lucide-svelte": "^0.453.0",
		"tailwind-merge": "^2.5.4",
		"tailwind-variants": "^0.2.1"
	}
}
